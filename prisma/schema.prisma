generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  password     String
  role         UserRole @default(USER)
  phone        String?
  avatar       String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  properties   Property[]
  transactions Transaction[]
  requisitions Requisition[]

  @@index([email])
  @@index([role])
}

model Property {
  id          String   @id @default(cuid())
  title       String
  description String?
  address     String
  suburb      String
  city        String   @default("Mutare")
  province    String   @default("Manicaland")
  latitude    Float
  longitude   Float
  price       Float
  bedrooms    Int
  bathrooms   Int
  squareMeters Float?
  propertyType PropertyType @default(HOUSE)
  listingType  ListingType  @default(WHOLE_HOUSE)
  status      PropertyStatus @default(AVAILABLE)
  amenities   String[]
  images      String[]

  // Construction & Condition
  houseConstruction HouseConstruction @default(BRICK)
  roofType          RoofType          @default(IRON_SHEETS)
  windowCondition   Condition         @default(GOOD)
  wallCondition     Condition         @default(GOOD)
  bathroomType      BathroomType      @default(SHOWER_ONLY)

  // Utilities
  hasWater            Boolean  @default(false)
  hasElectricity      Boolean  @default(false)
  hasRefuseCollection Boolean  @default(false)
  hasSecurity         Boolean  @default(false)
  hasWifi             Boolean  @default(false)
  hasBorehole         Boolean  @default(false)
  hasDriveway         Boolean  @default(false)
  hasPool             Boolean  @default(false)
  hasGenerator        Boolean  @default(false)
  hasSolarPower       Boolean  @default(false)

  yearBuilt   Int?
  algorithm   PricingAlgorithm @default(HEDONIC)

  // Contact
  contactName  String
  contactPhone String
  contactEmail String?
  contactRole  ContactRole @default(LANDLORD)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  views       Int      @default(0)

  userId      String?
  user        User?    @relation(fields: [userId], references: [id])

  transactions Transaction[]

  @@index([suburb])
  @@index([price])
  @@index([bedrooms])
  @@index([status])
  @@index([userId])
  @@index([propertyType])
  @@index([listingType])
}

model Transaction {
  id             String   @id @default(cuid())
  propertyId     String
  property       Property @relation(fields: [propertyId], references: [id])
  buyerId        String?
  buyer          User?    @relation(fields: [buyerId], references: [id])
  listedPrice    Float
  soldPrice      Float?
  predictedPrice Float?
  status         TransactionStatus @default(LISTED)
  listedAt       DateTime @default(now())
  soldAt         DateTime?
  createdAt      DateTime @default(now())

  @@index([propertyId])
  @@index([buyerId])
  @@index([status])
}

model PricePrediction {
  id           String   @id @default(cuid())
  suburb       String
  bedrooms     Int
  bathrooms    Int
  squareMeters Float?
  hasWater     Boolean
  hasElectricity Boolean
  hasSecurity  Boolean
  algorithm    PricingAlgorithm @default(HEDONIC)
  predictedPrice Float
  confidence   Float
  createdAt    DateTime @default(now())
}

model Requisition {
  id             String            @id @default(cuid())
  userId         String?
  user           User?             @relation(fields: [userId], references: [id])
  suburb         String?
  propertyType   PropertyType?
  listingType    ListingType?
  minBedrooms    Int?
  maxBedrooms    Int?
  maxBudget      Float?
  hasWater       Boolean?
  hasElectricity Boolean?
  hasSecurity    Boolean?
  hasWifi        Boolean?
  notes          String?
  status         RequisitionStatus @default(OPEN)
  estimatedMin   Float?
  estimatedMax   Float?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([userId])
  @@index([status])
}

enum UserRole {
  USER
  ADMIN
}

enum PropertyType {
  HOUSE
  FLAT
  ROOM
  TOWNHOUSE
  COTTAGE
}

enum ListingType {
  WHOLE_HOUSE
  ROOM
}

enum HouseConstruction {
  BRICK
  WOOD
  METAL
  MIXED
  STONE
}

enum RoofType {
  TILES
  ASBESTOS
  IRON_SHEETS
  THATCH
  CONCRETE
}

enum Condition {
  EXCELLENT
  GOOD
  FAIR
  POOR
}

enum BathroomType {
  SHOWER_ONLY
  TUB_ONLY
  SHOWER_AND_TUB
  NONE
}

enum ContactRole {
  LANDLORD
  ESTATE_AGENT
  PROPERTY_MANAGER
  CARETAKER
}

enum PricingAlgorithm {
  HEDONIC
  COMPARABLE_SALES
  COST_APPROACH
}

enum PropertyStatus {
  AVAILABLE
  RENTED
  PENDING
}

enum TransactionStatus {
  LISTED
  PENDING
  SOLD
  CANCELLED
}

enum RequisitionStatus {
  OPEN
  MATCHED
  CLOSED
}
